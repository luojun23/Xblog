	<!--实体映射-->
	<resultMap id="base_result_map" type="com.njtech.blog.entity.po.Resource">
		<!--id-->
		<id column="id" property="id"  />
		<!--用户ID-->
		<result column="user_id" property="userId"  />
		<!--资源类型-->
		<result column="type" property="type"  />
		<!--资源路径-->
		<result column="path" property="path"  />
		<!--资源内容的大小，单位：字节-->
		<result column="size" property="size"  />
		<!--文件名称-->
		<result column="original_name" property="originalName"  />
		<!--资源的 MIME 类型-->
		<result column="mime_type" property="mimeType"  />
		<!--是否启用[0:否，1:是]-->
		<result column="status" property="status"  />
		<!--存储平台-->
		<result column="store_type" property="storeType"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 id,user_id,type,path,size,
		 original_name,mime_type,status,store_type,create_time
		 
	</sql>

	<sql id="base_condition_filed">
			<if test="query.id != null">
				 and  id = #{query.id}
			</if>
			<if test="query.userId != null">
				 and  user_id = #{query.userId}
			</if>
			<if test="query.type != null and query.type!=''">
				 and  type = #{query.type}
			</if>
			<if test="query.path != null and query.path!=''">
				 and  path = #{query.path}
			</if>
			<if test="query.size != null">
				 and  size = #{query.size}
			</if>
			<if test="query.originalName != null and query.originalName!=''">
				 and  original_name = #{query.originalName}
			</if>
			<if test="query.mimeType != null and query.mimeType!=''">
				 and  mime_type = #{query.mimeType}
			</if>
			<if test="query.status != null">
				 and  status = #{query.status}
			</if>
			<if test="query.storeType != null and query.storeType!=''">
				 and  store_type = #{query.storeType}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>
	<!-- 通用条件列-->
	<sql id="base_condition">
	 <where>
		 <include refid="base_condition_filed" />
	 </where>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.typeFuzzy!= null  and query.typeFuzzy!=''">
				 and  type like concat('%', #{query.typeFuzzy}, '%')
			</if>
			<if test="query.pathFuzzy!= null  and query.pathFuzzy!=''">
				 and  path like concat('%', #{query.pathFuzzy}, '%')
			</if>
			<if test="query.originalNameFuzzy!= null  and query.originalNameFuzzy!=''">
				 and  original_name like concat('%', #{query.originalNameFuzzy}, '%')
			</if>
			<if test="query.mimeTypeFuzzy!= null  and query.mimeTypeFuzzy!=''">
				 and  mime_type like concat('%', #{query.mimeTypeFuzzy}, '%')
			</if>
			<if test="query.storeTypeFuzzy!= null  and query.storeTypeFuzzy!=''">
				 and  store_type like concat('%', #{query.storeTypeFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM resource <include refid="query_condition" />
		 <if test="query.orderBy!=null">
