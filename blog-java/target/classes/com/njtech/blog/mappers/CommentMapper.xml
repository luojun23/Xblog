	<sql id="base_condition_filed">
			<if test="query.id != null">
				 and  id = #{query.id}
			</if>
			<if test="query.source != null">
				 and  source = #{query.source}
			</if>
			<if test="query.type != null and query.type!=''">
				 and  type = #{query.type}
			</if>
			<if test="query.parentCommentId != null">
				 and  parent_comment_id = #{query.parentCommentId}
			</if>
			<if test="query.userId != null">
				 and  user_id = #{query.userId}
			</if>
			<if test="query.floorCommentId != null">
				 and  floor_comment_id = #{query.floorCommentId}
			</if>
			<if test="query.parentUserId != null">
				 and  parent_user_id = #{query.parentUserId}
			</if>
			<if test="query.likeCount != null">
				 and  like_count = #{query.likeCount}
			</if>
			<if test="query.commentContent != null and query.commentContent!=''">
				 and  comment_content = #{query.commentContent}
			</if>
			<if test="query.commentInfo != null and query.commentInfo!=''">
				 and  comment_info = #{query.commentInfo}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>
	<!-- 通用条件列-->
	<sql id="base_condition">
	 <where>
		 <include refid="base_condition_filed" />
	 </where>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.typeFuzzy!= null  and query.typeFuzzy!=''">
				 and  type like concat('%', #{query.typeFuzzy}, '%')
			</if>
			<if test="query.commentContentFuzzy!= null  and query.commentContentFuzzy!=''">
				 and  comment_content like concat('%', #{query.commentContentFuzzy}, '%')
			</if>
			<if test="query.commentInfoFuzzy!= null  and query.commentInfoFuzzy!=''">
				 and  comment_info like concat('%', #{query.commentInfoFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

