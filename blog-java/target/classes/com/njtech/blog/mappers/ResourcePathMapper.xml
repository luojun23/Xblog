	<!--实体映射-->
	<resultMap id="base_result_map" type="com.njtech.blog.entity.po.ResourcePath">
		<!--id-->
		<id column="id" property="id"  />
		<!--标题-->
		<result column="title" property="title"  />
		<!--分类-->
		<result column="classify" property="classify"  />
		<!--封面-->
		<result column="cover" property="cover"  />
		<!--链接-->
		<result column="url" property="url"  />
		<!--简介-->
		<result column="introduction" property="introduction"  />
		<!--资源类型-->
		<result column="type" property="type"  />
		<!--是否启用[0:否，1:是]-->
		<result column="status" property="status"  />
		<!--备注-->
		<result column="remark" property="remark"  />
		<!--创建时间-->
		<result column="create_time" property="createTime"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 id,title,classify,cover,url,
		 introduction,type,status,remark,create_time
		 
	</sql>

	<sql id="base_condition_filed">
			<if test="query.id != null">
				 and  id = #{query.id}
			</if>
			<if test="query.title != null and query.title!=''">
				 and  title = #{query.title}
			</if>
			<if test="query.classify != null and query.classify!=''">
				 and  classify = #{query.classify}
			</if>
			<if test="query.cover != null and query.cover!=''">
				 and  cover = #{query.cover}
			</if>
			<if test="query.url != null and query.url!=''">
				 and  url = #{query.url}
			</if>
			<if test="query.introduction != null and query.introduction!=''">
				 and  introduction = #{query.introduction}
			</if>
			<if test="query.type != null and query.type!=''">
				 and  type = #{query.type}
			</if>
			<if test="query.status != null">
				 and  status = #{query.status}
			</if>
			<if test="query.remark != null and query.remark!=''">
				 and  remark = #{query.remark}
			</if>
			<if test="query.createTime != null and query.createTime!=''">
				 <![CDATA[ and  create_time=str_to_date(#{query.createTime}, '%Y-%m-%d') ]]>
			</if>
	</sql>
	<!-- 通用条件列-->
	<sql id="base_condition">
	 <where>
		 <include refid="base_condition_filed" />
	 </where>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
	 <where>
			<include refid="base_condition_filed" />
			<if test="query.titleFuzzy!= null  and query.titleFuzzy!=''">
				 and  title like concat('%', #{query.titleFuzzy}, '%')
			</if>
			<if test="query.classifyFuzzy!= null  and query.classifyFuzzy!=''">
				 and  classify like concat('%', #{query.classifyFuzzy}, '%')
			</if>
			<if test="query.coverFuzzy!= null  and query.coverFuzzy!=''">
				 and  cover like concat('%', #{query.coverFuzzy}, '%')
			</if>
			<if test="query.urlFuzzy!= null  and query.urlFuzzy!=''">
				 and  url like concat('%', #{query.urlFuzzy}, '%')
			</if>
			<if test="query.introductionFuzzy!= null  and query.introductionFuzzy!=''">
				 and  introduction like concat('%', #{query.introductionFuzzy}, '%')
			</if>
			<if test="query.typeFuzzy!= null  and query.typeFuzzy!=''">
				 and  type like concat('%', #{query.typeFuzzy}, '%')
			</if>
			<if test="query.remarkFuzzy!= null  and query.remarkFuzzy!=''">
				 and  remark like concat('%', #{query.remarkFuzzy}, '%')
			</if>
			<if test="query.createTimeStart!= null and query.createTimeStart!=''">
				 <![CDATA[ and  create_time>=str_to_date(#{query.createTimeStart}, '%Y-%m-%d') ]]>
			</if>
			<if test="query.createTimeEnd!= null and query.createTimeEnd!=''">
				 <![CDATA[ and  create_time< date_sub(str_to_date(#{query.createTimeEnd},'%Y-%m-%d'),interval -1 day) ]]>
			</if>
	 </where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM resource_path <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
